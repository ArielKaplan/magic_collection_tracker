{
  "name": "secret-lair-tracker",
  "version": "0.33.0",
  "description": "MTG Secret Lair & collection tracker — desktop edition",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev": "npm run build:renderer && electron . --dev",
    "build:renderer": "vite build",
    "build:renderer:watch": "vite build --watch",
    "build": "npm run build:renderer && electron-builder",
    "release": "npm run build:renderer && electron-builder --win --publish always",
    "release:tag": "node scripts/release.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run"
  },
  "author": "Akapl",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArielKaplan/magic_collection_tracker.git"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "svelte": "^4.2.19",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "interactjs": "^1.10.27"
  },
  "build": {
    "appId": "com.akapl.secretlairtracker",
    "productName": "Secret Lair Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ArielKaplan",
        "repo": "magic_collection_tracker",
        "releaseType": "release"
      }
    ]
  }
}
