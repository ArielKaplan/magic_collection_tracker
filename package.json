{
  "name": "secret-lair-tracker",
  "version": "0.5.0",
  "description": "MTG Secret Lair & collection tracker — desktop edition",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev": "npm run build:renderer && electron . --dev",
    "build:renderer": "vite build",
    "build:renderer:watch": "vite build --watch",
    "build": "npm run build:renderer && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "author": "Akapl",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "svelte": "^4.2.19",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "chart.js": "^4.5.1",
    "interactjs": "^1.10.27"
  },
  "build": {
    "appId": "com.akapl.secretlairtracker",
    "productName": "Secret Lair Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
